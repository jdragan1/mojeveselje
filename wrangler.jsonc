{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mojeveselje",
  "compatibility_date": "2026-07-14",
  "main": "worker.js",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "INVITES",
      "id": "d5ce73c91098405b957b951f73f5c862"
    }
  ]
}
